# Copy these values into your shell or a local .env file as needed.
# Spring Boot and Umi do not automatically load this file in the current scaffold.

# Backend datasource used by local backend runs against Compose MySQL.
DOCUMENT_CENTER_DATASOURCE_URL=jdbc:mysql://localhost:13306/document_center?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
DOCUMENT_CENTER_DATASOURCE_USERNAME=root
DOCUMENT_CENTER_DATASOURCE_PASSWORD=root

# Backend object storage. Default local dependency is Compose MinIO.
DOCUMENT_CENTER_STORAGE_TYPE=s3
DOCUMENT_CENTER_STORAGE_S3_ENDPOINT=http://localhost:19000
DOCUMENT_CENTER_STORAGE_S3_REGION=us-east-1
DOCUMENT_CENTER_STORAGE_S3_BUCKET=document-center
DOCUMENT_CENTER_STORAGE_S3_ACCESS_KEY=document-center
DOCUMENT_CENTER_STORAGE_S3_SECRET_KEY=document-center-secret
DOCUMENT_CENTER_STORAGE_S3_PATH_STYLE_ACCESS=true
DOCUMENT_CENTER_STORAGE_ROOT_PATH=./data/document-center/objects
DOCUMENT_CENTER_STORAGE_PUBLIC_BASE_PATH=/api/v1/document-center/assets

# Frontend dev proxy.
DOCUMENT_CENTER_API_PROXY_TARGET=http://localhost:8080
